# OpenRouter API key (get from https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-v1-...

# Optional: OpenAI API key (if you prefer)
# OPENAI_API_KEY=sk-...

# Model to use (OpenRouter free model recommended)
MODEL=mistralai/mixtral-8x7b-instruct:free

# Audio settings
SAMPLE_RATE=16000
RECORD_DURATION=5  # seconds

# Hotkey (default: Cmd+Option+J on Mac, Ctrl+Alt+J on Linux/Windows)
# Uses pynput syntax: '<cmd>+<alt>+j' or '<ctrl>+<alt>+j'
