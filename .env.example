# OpenRouter API key (get from https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-v1-...

# Optional: OpenAI API key (if you prefer)
# OPENAI_API_KEY=sk-...

# Model to use (OpenRouter free model recommended)
MODEL=openrouter/auto

# Audio settings
SAMPLE_RATE=16000
RECORD_DURATION=3  # command recording length (seconds)

# Wake word mode: set WAKE_WORD to enable always-listening (e.g., "MJ")
# Leave empty to use hotkey mode
WAKE_WORD=mj
WAKE_WORD_DURATION=2  # how long to listen for wake word each loop
COMMAND_DURATION=3  # how long to record after wake word

# Hotkey (default: Cmd+Option+J on Mac, Ctrl+Alt+J on Linux/Windows)
# Used only when WAKE_WORD is not set
HOTKEY=<cmd>+<alt>+j

# Text-to-Speech settings (macOS only)
# List voices: say -v '?'
VOICE=Lekha  # female voice (e.g., Victoria, Samantha, Veena, Lekha)
RATE=180     # words per minute (default ~175)
